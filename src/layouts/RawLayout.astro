---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		{/* Fragment pages are fetched by the client-side slide loader and must stay out of search results. */}
		<meta name="robots" content="noindex, nofollow" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
